{
	"name": "detain/myadmin-xen-vps",
	"type": "myadmin-plugin",
	"description": "MyAdmin Xen VPS plugin — provides event-driven provisioning, deactivation, and queue management for Xen hypervisor-based virtual private servers within the MyAdmin framework.",
	"keywords": [
		"xen",
		"vps",
		"virtualization",
		"hypervisor",
		"myadmin",
		"plugin",
		"provisioning",
		"administration"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=7.4",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminXen\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminXen\\Tests\\": "tests/"
		}
	}
}
